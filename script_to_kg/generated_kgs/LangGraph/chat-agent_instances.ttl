# Execution time: 39.54 seconds
# Model used: gpt-5-mini
# Prompt: P5

# Framework: LangGraph

# Issues / Assumptions:
# - Assumption: agent.name "Chat Agent" is used as :agentID since no explicit agent ID was provided.
# - Assumption: no explicit agent role in code; assigned :agentRole "assistant".
# - Assumption: state.messages content is runtime-dependent/unknown; represented in :promptContext of task prompt.
# - No tools, memories, or explicit end constant detected; marked the node "chat" as :EndStep because it has no outgoing edges.
# - No Config entries found in code (e.g., API keys or parameters).

@prefix : <http://www.w3id.org/agentic-ai/onto#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix beam: <http://w3id.org/beam/core#> .

:team_stategraph rdf:type :Team ;
    dcterms:title "StateGraph Team" ;
    :hasWorkflowPattern :wp_stategraph ;
    :hasAgentMember :agent_chat .

:wp_stategraph rdf:type :WorkflowPattern ;
    dcterms:title "StateGraph" ;
    :hasWorkflowStep :START , :chat .

:START rdf:type :StartStep , :WorkflowStep ;
    dcterms:title "START" ;
    :stepOrder 1 ;
    :nextStep :chat .

:chat rdf:type :EndStep , :WorkflowStep ;
    dcterms:title "chat" ;
    :stepOrder 2 ;
    :hasAssociatedTask :task_chat .

:task_chat rdf:type :Task ;
    dcterms:title "chat task" ;
    :performedByAgent :agent_chat ;
    :taskPrompt :prompt_task .

:agent_chat rdf:type :LLMAgent ;
    dcterms:title "Chat Agent" ;
    :agentID "Chat Agent" ;
    :agentRole "assistant" ;
    :agentPrompt :prompt_system ;
    :useLanguageModel :lm_gpt4o_mini .

:prompt_system rdf:type :Prompt ;
    :promptInstruction "You are a helpful assistant." ;
    dcterms:description "System message used when invoking the chat model." .

:prompt_task rdf:type :Prompt ;
    :promptInstruction "Invoke model with the system prompt and current state.messages; return response messages." ;
    :promptContext "Includes state.messages from the runtime StateGraph (content not available statically)." ;
    :promptOutputIndicator "Chat response messages" .

:lm_gpt4o_mini rdf:type :LanguageModel ;
    dcterms:title "gpt-4o-mini" ;
    dcterms:description "Language model instantiated via ChatOpenAI({ model: \"gpt-4o-mini\" }) in code." .