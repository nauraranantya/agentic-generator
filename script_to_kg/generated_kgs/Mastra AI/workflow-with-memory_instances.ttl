########################
# Workflows - cyclicalWorkflow
########################

:wf_cyclical rdf:type :WorkflowPattern ;
    dcterms:title "cyclical-workflow" ;
    dcterms:description "Workflow with conditional and cyclical step references defined in src/mastra/workflows/index.ts" ;
    :hasWorkflowStep :cyc_stepOne_start , :cyc_stepTwo , :cyc_stepThree , :cyc_stepOne_loop_end .

:cyc_stepOne_start rdf:type :StartStep , :WorkflowStep ;
    dcterms:title "stepOne" ;
    :stepOrder 1 ;
    :hasAssociatedTask :task_cyc_stepOne ;
    :nextStep :cyc_stepTwo .

:cyc_stepTwo rdf:type :WorkflowStep ;
    dcterms:title "stepTwo" ;
    :stepOrder 2 ;
    :hasAssociatedTask :task_cyc_stepTwo ;
    :nextStep :cyc_stepThree .

:cyc_stepThree rdf:type :WorkflowStep ;
    dcterms:title "stepThree" ;
    :stepOrder 3 ;
    :hasAssociatedTask :task_cyc_stepThree ;
    :nextStep :cyc_stepOne_loop_end ;
    dcterms:description "Conditional step executed when stepOne.doubledValue == 10" .

:cyc_stepOne_loop_end rdf:type :EndStep , :WorkflowStep ;
    dcterms:title "stepOne_loop" ;
    :stepOrder 4 ;
    :hasAssociatedTask :task_cyc_stepOne_loop ;
    dcterms:description "Cyclical stepOne invocation conditioned on previous outputs (when doubledValue == 12)" .

########################
# Tasks and Prompts for cyclical workflow
########################

:task_cyc_stepOne rdf:type :Task ;
    dcterms:title "task_cyc_stepOne" ;
    :performedByAgent :catOneAgent ;
    :taskPrompt :prompt_cyc_stepOne ;
    dcterms:description "Doubles the input value (cyclical workflow start)" .

:prompt_cyc_stepOne rdf:type :Prompt ;
    :promptInstruction "Doubles the input value" ;
    :promptInputData "inputValue: number" ;
    :promptOutputIndicator "doubledValue" .

:task_cyc_stepTwo rdf:type :Task ;
    dcterms:title "task_cyc_stepTwo" ;
    :performedByAgent :catOneAgent ;
    :taskPrompt :prompt_cyc_stepTwo ;
    dcterms:description "Adds 1 to the input value (cyclical workflow)" .

:prompt_cyc_stepTwo rdf:type :Prompt ;
    :promptInstruction "Adds 1 to the input value" ;
    :promptInputData "valueToIncrement: number" ;
    :promptOutputIndicator "incrementedValue" .

:task_cyc_stepThree rdf:type :Task ;
    dcterms:title "task_cyc_stepThree" ;
    :performedByAgent :catOneAgent ;
    :taskPrompt :prompt_cyc_stepThree ;
    dcterms:description "Squares the input value when condition met (doubledValue == 10)" .

:prompt_cyc_stepThree rdf:type :Prompt ;
    :promptInstruction "Squares the input value" ;
    :promptInputData "valueToSquare: number" ;
    :promptOutputIndicator "squaredValue" ;
    dcterms:description "This step has a when condition referencing stepOne.doubledValue == 10" .

:task_cyc_stepOne_loop rdf:type :Task ;
    dcterms:title "task_cyc_stepOne_loop" ;
    :performedByAgent :catOneAgent ;
    :taskPrompt :prompt_cyc_stepOne_loop ;
    dcterms:description "Re-invocation of stepOne under condition (doubledValue == 12)" .

:prompt_cyc_stepOne_loop rdf:type :Prompt ;
    :promptInstruction "Doubles the input value (loop invocation)" ;
    :promptInputData "inputValue: number" ;
    :promptOutputIndicator "doubledValue" ;
    dcterms:description "This step represents a cyclical re-run of stepOne when a condition is met." .