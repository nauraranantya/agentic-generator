# Execution time: 63.69 seconds
# Model used: gpt-5-mini
# Prompt: P5

# Framework: Mastra AI

# Issues / Assumptions:
# - No issues detected

@prefix : <http://www.w3id.org/agentic-ai/onto#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix beam: <http://w3id.org/beam/core#> .

########################
# Agent
########################

:catOneAgent rdf:type :LLMAgent ;
    :agentID "cat-one" ;
    :agentRole "feline-expert" ;
    :agentPrompt :prompt_catOne_instructions ;
    :useLanguageModel :lm_gpt4o ;
    :agentToolUsage :tool_GetCatFacts ;
    :hasAgentConfig :agentConfig_catOne ;
    :hasKnowledge :pgMemory_instance ;
    dcterms:description "Agent defined in src/mastra/agents/index.ts" .

:prompt_catOne_instructions rdf:type :Prompt ;
    :promptInstruction "You are a feline expert with comprehensive knowledge of all cat species, from domestic breeds to wild big cats. As a lifelong cat specialist, you understand their behavior, biology, social structures, and evolutionary history in great depth." .

:lm_gpt4o rdf:type :LanguageModel ;
    dcterms:title "gpt-4o" ;
    dcterms:description "Language model configured for cat-one (provider OPEN_AI, name gpt-4o)." .

:agentConfig_catOne rdf:type :Config ;
    :configKey "model.provider" ;
    :configValue "OPEN_AI" ;
    dcterms:description "Agent model provider" .

:agentConfig_catOne_2 rdf:type :Config ;
    :configKey "model.name" ;
    :configValue "gpt-4o" .

:agentConfig_catOne_3 rdf:type :Config ;
    :configKey "toolChoice" ;
    :configValue "auto" .

# link multiple agent configs to agent
:catOneAgent :hasAgentConfig :agentConfig_catOne , :agentConfig_catOne_2 , :agentConfig_catOne_3 .

########################
# Tool
########################

:tool_GetCatFacts rdf:type :Tool ;
    dcterms:title "Get cat facts" ;
    dcterms:description "Fetches cat facts" ;
    :hasCapability :cap_GetCatFacts ;
    :hasToolConfig :toolConfig_GetCatFacts .

:cap_GetCatFacts rdf:type :Capability ;
    dcterms:title "Fetch cat facts" ;
    dcterms:description "Returns a cat fact string from an external API (catfact.ninja)." .

:toolConfig_GetCatFacts rdf:type :Config ;
    :configKey "id" ;
    :configValue "Get cat facts" ;
    dcterms:description "Tool identifier as provided in createTool call." .

########################
# Memory
########################

:pgMemory_instance rdf:type :Memory ;
    dcterms:title "PgMemory" ;
    dcterms:description "Postgres-backed memory instance (PgMemory) provided to Mastra via environment variable POSTGRES_URL)." .

########################
# Team (Mastra instance)
########################

:mastraTeam rdf:type :Team ;
    dcterms:title "mastra-instance" ;
    :hasAgentMember :catOneAgent ;
    :hasWorkflowPattern :wf_sequential , :wf_parallel , :wf_branched , :wf_cyclical ;
    :hasSystemConfig :syscfg_logger_name , :syscfg_logger_level , :syscfg_memory_conn ;
    dcterms:description "Mastra instance configured in src/mastra/index.ts with one agent and four workflows." .

:syscfg_logger_name rdf:type :Config ;
    :configKey "logger.name" ;
    :configValue "Mastra" .

:syscfg_logger_level rdf:type :Config ;
    :configKey "logger.level" ;
    :configValue "debug" .

:syscfg_memory_conn rdf:type :Config ;
    :configKey "memory.connectionString" ;
    :configValue "env:POSTGRES_URL" ;
    dcterms:description "Connection string provided via environment variable POSTGRES_URL" .

########################
# Workflows - sequentialWorkflow
########################

:wf_sequential rdf:type :WorkflowPattern ;
    dcterms:title "sequential-workflow" ;
    dcterms:description "Workflow defined in src/mastra/workflows/index.ts (sequential)" ;
    :hasWorkflowStep :seq_stepOne_start , :seq_stepTwo , :seq_stepThree , :seq_stepFour , :seq_stepFive_end .

:seq_stepOne_start rdf:type :StartStep , :WorkflowStep ;
    dcterms:title "stepOne" ;
    :stepOrder 1 ;
    :hasAssociatedTask :task_stepOne ;
    :nextStep :seq_stepTwo .

:seq_stepTwo rdf:type :WorkflowStep ;
    dcterms:title "stepTwo" ;
    :stepOrder 2 ;
    :hasAssociatedTask :task_stepTwo ;
    :nextStep :seq_stepThree .

:seq_stepThree rdf:type :WorkflowStep ;
    dcterms:title "stepThree" ;
    :stepOrder 3 ;
    :hasAssociatedTask :task_stepThree ;
    :nextStep :seq_stepFour .

:seq_stepFour rdf:type :WorkflowStep ;
    dcterms:title "stepFour" ;
    :stepOrder 4 ;
    :hasAssociatedTask :task_stepFour ;
    :nextStep :seq_stepFive_end .

:seq_stepFive_end rdf:type :EndStep , :WorkflowStep ;
    dcterms:title "stepFive" ;
    :stepOrder 5 ;
    :hasAssociatedTask :task_stepFive .

########################
# Tasks and Prompts for sequential workflow steps
########################

:task_stepOne rdf:type :Task ;
    dcterms:title "task_stepOne" ;
    :performedByAgent :catOneAgent ;
    :taskPrompt :prompt_task_stepOne ;
    dcterms:description "Doubles the input value" .

:prompt_task_stepOne rdf:type :Prompt ;
    :promptInstruction "Doubles the input value" ;
    :promptInputData "inputValue: number" ;
    :promptOutputIndicator "doubledValue" .

:task_stepTwo rdf:type :Task ;
    dcterms:title "task_stepTwo" ;
    :performedByAgent :catOneAgent ;
    :taskPrompt :prompt_task_stepTwo ;
    dcterms:description "Adds 1 to the input value" .

:prompt_task_stepTwo rdf:type :Prompt ;
    :promptInstruction "Adds 1 to the input value" ;
    :promptInputData "valueToIncrement: number" ;
    :promptOutputIndicator "incrementedValue" .

:task_stepThree rdf:type :Task ;
    dcterms:title "task_stepThree" ;
    :performedByAgent :catOneAgent ;
    :taskPrompt :prompt_task_stepThree ;
    dcterms:description "Squares the input value" .

:prompt_task_stepThree rdf:type :Prompt ;
    :promptInstruction "Squares the input value" ;
    :promptInputData "valueToSquare: number" ;
    :promptOutputIndicator "squaredValue" .

:task_stepFour rdf:type :Task ;
    dcterms:title "task_stepFour" ;
    :performedByAgent :catOneAgent ;
    :taskPrompt :prompt_task_stepFour ;
    dcterms:description "Gives the square root of the input value" .

:prompt_task_stepFour rdf:type :Prompt ;
    :promptInstruction "Gives the square root of the input value" ;
    :promptInputData "valueToRoot: number" ;
    :promptOutputIndicator "rootValue" .

:task_stepFive rdf:type :Task ;
    dcterms:title "task_stepFive" ;
    :performedByAgent :catOneAgent ;
    :taskPrompt :prompt_task_stepFive ;
    dcterms:description "Triples the input value" .

:prompt_task_stepFive rdf:type :Prompt ;
    :promptInstruction "Triples the input value" ;
    :promptInputData "inputValue: number" ;
    :promptOutputIndicator "tripledValue" .

########################
# Workflows - parallelWorkflow
########################

:wf_parallel rdf:type :WorkflowPattern ;
    dcterms:title "parallel-workflow" ;
    dcterms:description "Workflow defined in src/mastra/workflows/index.ts (parallel branches)" ;
    :hasWorkflowStep :par_stepOne_start , :par_stepSix , :par_stepTwo , :par_stepThree_end .

:par_stepOne_start rdf:type :StartStep , :WorkflowStep ;
    dcterms:title "stepOne" ;
    :stepOrder 1 ;
    :hasAssociatedTask :task_par_stepOne ;
    :nextStep :par_stepSix , :par_stepTwo , :par_stepThree .

:par_stepSix rdf:type :WorkflowStep ;
    dcterms:title "stepSix" ;
    :stepOrder 2 ;
    :hasAssociatedTask :task_par_stepSix ;
    dcterms:description "Logs the input value" .

:par_stepTwo rdf:type :WorkflowStep ;
    dcterms:title "stepTwo" ;
    :stepOrder 3 ;
    :hasAssociatedTask :task_par_stepTwo .

:par_stepThree_end rdf:type :EndStep , :WorkflowStep ;
    dcterms:title "stepThree" ;
    :stepOrder 4 ;
    :hasAssociatedTask :task_par_stepThree .

########################
# Tasks and Prompts for parallel workflow
########################

:task_par_stepOne rdf:type :Task ;
    dcterms:title "task_par_stepOne" ;
    :performedByAgent :catOneAgent ;
    :taskPrompt :prompt_par_stepOne ;
