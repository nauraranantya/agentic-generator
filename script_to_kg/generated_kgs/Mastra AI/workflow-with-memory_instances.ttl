:prompt_par_stepOne rdf:type :Prompt ;
    :promptInstruction "Doubles the input value" ;
    :promptInputData "inputValue: number" ;
    :promptOutputIndicator "doubledValue" .

:task_par_stepSix rdf:type :Task ;
    dcterms:title "task_par_stepSix" ;
    :performedByAgent :catOneAgent ;
    :taskPrompt :prompt_par_stepSix ;
    dcterms:description "Logs the input value and returns rawText" .

:prompt_par_stepSix rdf:type :Prompt ;
    :promptInstruction "Logs the input value" ;
    :promptInputData "inputValue: number" ;
    :promptOutputIndicator "rawText" .

:task_par_stepTwo rdf:type :Task ;
    dcterms:title "task_par_stepTwo" ;
    :performedByAgent :catOneAgent ;
    :taskPrompt :prompt_par_stepTwo ;
    dcterms:description "Adds 1 to the input value (parallel branch)" .

:prompt_par_stepTwo rdf:type :Prompt ;
    :promptInstruction "Adds 1 to the input value" ;
    :promptInputData "valueToIncrement: number" ;
    :promptOutputIndicator "incrementedValue" .

:task_par_stepThree rdf:type :Task ;
