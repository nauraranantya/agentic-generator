# Execution time: 38.68 seconds
# Model used: gpt-5-mini
# Prompt: P5

# Framework: CrewAI

# Issues / Assumptions:
# - No runtime filename available at extraction time; represented as configValue "runtime: sys.argv[1]".
# - Default LLM is taken from main.py default (model_name env default "gpt-4o-mini"); created explicit :LanguageModel individual.
# - Single-step workflow modeled as one step typed as both :StartStep and :EndStep (stepOrder 1).
# - Agent ID and names derived from code/config keys (Requirements_Manager -> "Requirements_Manager").

@prefix : <http://www.w3id.org/agentic-ai/onto#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix beam: <http://w3id.org/beam/core#> .

### Agent: Requirements Manager
:RequirementsManagerAgent rdf:type :LLMAgent ;
    :agentID "Requirements_Manager" ;
    :agentRole "Requirements Manager" ;
    :agentPrompt :agentPrompt_RequirementsManager ;
    :hasAgentGoal :Goal_RequirementsManager ;
    :agentToolUsage :markdown_validation_tool ;
    :useLanguageModel :gpt4o_mini ;
    :hasAgentConfig :agentConfig_allow_delegation , :agentConfig_verbose ;
    dcterms:title "Requirements Manager (agent)" .

:agentPrompt_RequirementsManager rdf:type :Prompt ;
    :promptInstruction """You are an expert business analyst and software QA specialist.
You provide high quality, thorough, insightful, and actionable feedback via a detailed list of changes and actionable tasks.""" .

:Goal_RequirementsManager rdf:type :Goal ;
    dcterms:description """Provide a detailed list of the markdown linting results.
Give a summary with actionable tasks to address the validation results.
Write your response as if you were handing it to a developer to fix the issues.
DO NOT provide examples of how to fix the issues or recommend other tools to use.""" .

### Language Model (created from main.py default)
:gpt4o_mini rdf:type :LanguageModel ;
    dcterms:title "gpt-4o-mini" ;
    dcterms:description "Default LLM configured in main.py (ChatOpenAI model_name env default)" .

### Tool: markdown_validation_tool
:markdown_validation_tool rdf:type :Tool ;
    dcterms:title "markdown_validation_tool" ;
    dcterms:description "A tool to review files for markdown syntax errors. Uses PyMarkdownApi to scan a file path and returns formatted scan results." ;
    :hasCapability :MarkdownLintCapability .

:MarkdownLintCapability rdf:type :Capability ;
    dcterms:description "Identify markdown syntax issues using pymarkdown, returning formatted scan failures (file, line, rule, description)." .

### Task: syntax_review_task
:syntax_review_task rdf:type :Task ;
    dcterms:description """Use the markdown_validation_tool to review the file(s) at this path: {filename}.
Be sure to pass only the file path to the markdown_validation_tool.
Use the following format to call the markdown_validation_tool:
Do I need to use a tool? Yes
Action: markdown_validation_tool
Action Input: {filename}

Get the validation results from the tool and then summarize it into a list of changes
the developer should make to the document.
DO NOT recommend ways to update the document.
DO NOT change any of the content of the document or add content to it.
It is critical to your task to only respond with a list of changes.

If you already know the answer or if you do not need to use a tool,
return it as your Final Answer.""" ;
    :taskPrompt :taskPrompt_syntax_review ;
    :performedByAgent :RequirementsManagerAgent ;
    dcterms:title "syntax_review_task" .

:taskPrompt_syntax_review rdf:type :Prompt ;
    :promptInstruction """Use the markdown_validation_tool to review the file(s) at this path: {filename}.
Be sure to pass only the file path to the markdown_validation_tool.
Use the following format to call the markdown_validation_tool:
Do I need to use a tool? Yes
Action: markdown_validation_tool
Action Input: {filename}

Get the validation results from the tool and then summarize it into a list of changes
the developer should make to the document.
DO NOT recommend ways to update the document.
DO NOT change any of the content of the document or add content to it.
It is critical to your task to only respond with a list of changes.

If you already know the answer or if you do not need to use a tool,
return it as your Final Answer.""" ;
    :promptOutputIndicator "A list of changes the developer should make to the document based on the markdown validation results." .

### Workflow: MarkDown Validator (sequential)
:MarkdownValidationWorkflow rdf:type :WorkflowPattern ;
    dcterms:title "Sequential" ;
    :hasWorkflowStep :Step_1 ;
    dcterms:description "Workflow pattern for the markdown validation crew (Process.sequential)" .

### Single workflow step (also StartStep and EndStep)
:Step_1 rdf:type :StartStep , :EndStep , :WorkflowStep ;
    :stepOrder 1 ;
    :hasAssociatedTask :syntax_review_task ;
    dcterms:title "Markdown Validation Step 1" .

### Team / Crew
:MarkDownValidatorCrewTeam rdf:type :Team ;
    dcterms:title "MarkDownValidatorCrew" ;
    :hasAgentMember :RequirementsManagerAgent ;
    :hasWorkflowPattern :MarkdownValidationWorkflow ;
    :hasSystemConfig :teamConfig_agents , :teamConfig_tasks , :teamConfig_query , :teamConfig_filename .

:teamConfig_agents rdf:type :Config ;
    :configKey "agents_config" ;
    :configValue "config/agents.yaml" .

:teamConfig_tasks rdf:type :Config ;
    :configKey "tasks_config" ;
    :configValue "config/tasks.yaml" .

:teamConfig_query rdf:type :Config ;
    :configKey "query" ;
    :configValue "Please provide the markdown file to analyze:" .

:teamConfig_filename rdf:type :Config ;
    :configKey "filename" ;
    :configValue "runtime: sys.argv[1]" .

### Agent configuration entries
:agentConfig_allow_delegation rdf:type :Config ;
    :configKey "allow_delegation" ;
    :configValue "False" .

:agentConfig_verbose rdf:type :Config ;
    :configKey "verbose" ;
    :configValue "False" .