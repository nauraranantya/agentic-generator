{# ────────────────────────────────────────────────────────
   Jinja2 Template: src/mastra/workflows/{workflow}.ts
   Generates Workflow + Step definitions using new createWorkflow/createStep API
   (Mastra v1.x+: replaces legacy new Workflow / new Step class-based API)
   ──────────────────────────────────────────────────────── #}
/**
 * Workflow: {{ workflow.workflow_id }}
 *
 * Auto-generated from AgentO Knowledge Graph
{% if workflow.description %}
 *
 * {{ workflow.description.split('\n')[0] | ts_escape }}
{% endif %}
 */

import { createWorkflow, createStep } from '@mastra/core/workflows'
import { z } from 'zod'
{% set ns = namespace(agent_vars=[], tool_vars=[]) %}
{% if workflow.steps %}
{% for step in workflow.steps %}
{% if step.agent_var_name and step.agent_var_name not in ns.agent_vars %}
{% set _ = ns.agent_vars.append(step.agent_var_name) %}
{% endif %}
{% if step.tool_var_name and step.tool_var_name not in ns.tool_vars %}
{% set _ = ns.tool_vars.append(step.tool_var_name) %}
{% endif %}
{% endfor %}
{% endif %}
{% if ns.agent_vars %}

// Import agents used by workflow steps
{% for agent_var in ns.agent_vars %}
import { {{ agent_var }} } from '../agents/{{ agent_var }}'
{% endfor %}
{% endif %}
{% if ns.tool_vars %}

// Import tools used by workflow steps
{% for tool_var in ns.tool_vars %}
import { {{ tool_var }} } from '../tools/{{ tool_var }}'
{% endfor %}
{% endif %}
{% if workflow.nested_workflow_var_names %}

// Import nested sub-workflows
{% for nwf_var in workflow.nested_workflow_var_names %}
import { {{ nwf_var }} } from './{{ nwf_var }}'
{% endfor %}
{% endif %}

{% if workflow.steps %}
// ── Workflow Steps ──
{% for step in workflow.steps %}

{% if step.is_suspend_resume %}
const {{ step.var_name }} = createStep({
  id: '{{ step.step_id }}',
{% if step.description %}
  description: `{{ step.description.split('\n')[0] | ts_escape }}`,
{% endif %}
{% if step.input_schema %}
  inputSchema: {{ step.input_schema }},
{% else %}
  inputSchema: z.object({}),
{% endif %}
{% if step.output_schema %}
  outputSchema: {{ step.output_schema }},
{% else %}
  outputSchema: z.object({}),
{% endif %}
  execute: async ({ inputData, suspend }) => {
    // Suspend/resume step
{% if step.resume_schema %}
    // resumeData schema: {{ step.resume_schema }}
{% endif %}
{% if step.agent_var_name %}
    // This step uses agent: {{ step.agent_var_name }}
{% endif %}
{% if step.execute_description %}
    // {{ step.execute_description.split('\n')[0] | ts_escape }}
{% endif %}
    // TODO: Check resume state and implement logic
    await suspend({
{% if step.suspend_message %}
      message: `{{ step.suspend_message | ts_escape }}`,
{% else %}
      message: 'Waiting for human input',
{% endif %}
    })
    throw new Error('{{ step.step_id }} resume handler not implemented yet')
  },
})
{% else %}
const {{ step.var_name }} = createStep({
  id: '{{ step.step_id }}',
{% if step.description %}
  description: `{{ step.description.split('\n')[0] | ts_escape }}`,
{% endif %}
{% if step.input_schema %}
  inputSchema: {{ step.input_schema }},
{% else %}
  inputSchema: z.object({}),
{% endif %}
{% if step.output_schema %}
  outputSchema: {{ step.output_schema }},
{% else %}
  outputSchema: z.object({}),
{% endif %}
  execute: async ({ inputData }) => {
{% if step.execute_description %}
    // {{ step.execute_description.split('\n')[0] | ts_escape }}
{% endif %}
{% if step.agent_var_name %}
    // This step uses agent: {{ step.agent_var_name }}
    // const result = await {{ step.agent_var_name }}.generate('...')
{% endif %}
{% if step.tool_var_name %}
    // This step uses tool: {{ step.tool_var_name }}
{% endif %}
    // TODO: Implement step logic
    throw new Error('{{ step.step_id }} not implemented yet')
  },
})
{% endif %}
{% endfor %}
{% endif %}

// ── Workflow Definition ──

/**
 * {{ workflow.workflow_id }}
{% if workflow.description %}
 *
 * {{ workflow.description.split('\n')[0] | ts_escape }}
{% endif %}
 */
{% if workflow.steps %}
export const {{ workflow.var_name }} = createWorkflow({
  id: '{{ workflow.workflow_id }}',
{% if workflow.input_schema %}
  inputSchema: {{ workflow.input_schema }},
{% else %}
  inputSchema: z.object({}),
{% endif %}
{% if workflow.output_schema %}
  outputSchema: {{ workflow.output_schema }},
{% else %}
  outputSchema: z.object({}),
{% endif %}
  steps: [{{ workflow.steps | map(attribute='var_name') | join(', ') }}],
})
{% if workflow.control_flow.value == 'branching' %}
  // NOTE: Branching workflow — simplified to sequential for type compatibility
  // TODO: Implement conditional branching using .branch() API
  .then({{ workflow.steps[0].var_name }})
{% for step in workflow.steps[1:] %}
  .then({{ step.var_name }}){% if step.condition %}  // condition: {{ step.condition | ts_escape }}{% endif %}

{% endfor %}
{% elif workflow.control_flow.value == 'parallel' %}
  .parallel([{{ workflow.steps | map(attribute='var_name') | join(', ') }}])
{% else %}
  .then({{ workflow.steps[0].var_name }})
{% for step in workflow.steps[1:] %}
  .then({{ step.var_name }})
{% endfor %}
{% endif %}
  .commit()
{% else %}
export const {{ workflow.var_name }} = createWorkflow({
  id: '{{ workflow.workflow_id }}',
{% if workflow.input_schema %}
  inputSchema: {{ workflow.input_schema }},
{% else %}
  inputSchema: z.object({}),
{% endif %}
  outputSchema: z.object({}),
  steps: [],
})
  .commit()
{% endif %}
