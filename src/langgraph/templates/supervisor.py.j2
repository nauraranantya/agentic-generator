# ===========================================================
# Supervisor Node
# ===========================================================

_WORKER_NAMES = [{% for a in agents %}"{{ a.var_name }}"{% if not loop.last %}, {% endif %}{% endfor %}]


def supervisor_node(state: AgentState) -> dict:
    """Routes work to the appropriate worker agent or finishes."""
    llm = ChatOpenAI(model=os.environ.get("LLM_MODEL", "gpt-4o"))
    options = ", ".join(_WORKER_NAMES) + ", or FINISH"
    prompt = (
        f"You are a supervisor managing these workers: {options}. "
        "Decide who should act next, or reply FINISH when done. "
        "Reply with only the worker name or FINISH."
    )
    sys_msg = SystemMessage(content=prompt)
    response = llm.invoke([sys_msg] + list(state["messages"]))

    route = "FINISH"
    for name in _WORKER_NAMES:
        if name in response.content:
            route = name
            break

    return {"next": route}


