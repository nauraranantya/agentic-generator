{% if agents and agents[0].provider == "anthropic" %}
import { ChatAnthropic } from "@langchain/anthropic";
{% else %}
import { ChatOpenAI } from "@langchain/openai";
{% endif %}
import { Annotation, START, END, StateGraph } from "@langchain/langgraph";

{% set model_class = "ChatAnthropic" if (agents and agents[0].provider == "anthropic") else "ChatOpenAI" %}
{% set model_name = agents[0].model_name if agents else "gpt-4o-mini" %}
{% set agent_prompt = agents[0].prompt if agents else "You are a helpful assistant." %}

const {{ graph_class_name }}Annotation = Annotation.Root({
  messages: Annotation<any[]>({
    reducer: (_, next) => next,
    default: () => [],
  }),
});

{% for node in nodes if not node.is_start and not node.is_end %}
async function {{ node.ts_name }}(state: typeof {{ graph_class_name }}Annotation.State) {
  const model = new {{ model_class }}({ model: "{{ model_name | ts_escape }}" });
  const response = await model.invoke([
    {
      role: "system",
      content:
        "{{ agent_prompt | ts_escape }}" +
        "\nNode: {{ node.ts_name }}",
    },
    ...state.messages,
  ]);
  return { messages: [response] };
}
{% endfor %}

{% set worker_nodes = nodes | rejectattr("is_start", "equalto", true) | rejectattr("is_end", "equalto", true) | list %}

const workflow = new StateGraph({{ graph_class_name }}Annotation)
{% for node in worker_nodes %}
  .addNode("{{ node.ts_name }}", {{ node.ts_name }})
{% endfor %}
{% for edge in edges %}
  .addEdge("{{ edge.source }}", "{{ edge.target }}")
{% endfor %}
;

export const graph = workflow.compile();
graph.name = "{{ graph_name | ts_escape }}";
