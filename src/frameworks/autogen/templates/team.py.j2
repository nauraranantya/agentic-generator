{% if goals or objectives or human_agents %}
"""
Auto-generated AutoGen Team: {{ project.name }}
{% if goals %}
Goals:
{% for g in goals %}
  - {{ g.label }}: {{ g.description }}
{% endfor %}
{% endif %}
{% if objectives %}
Objectives:
{% for o in objectives %}
  - {{ o.label }}: {{ o.description }}
{% endfor %}
{% endif %}
{% if human_agents %}
Human Agents:
{% for h in human_agents %}
  - {{ h.var_name }} ({{ h.role }})
{% endfor %}
{% endif %}
{% if environments %}
Environments:
{% for e in environments %}
  - {{ e.label }} ({{ e.env_type }}): {{ e.description }}
{% endfor %}
{% endif %}
{% if capabilities %}
Capabilities:
{% for c in capabilities %}
  - {{ c.label }}: {{ c.description }}
{% endfor %}
{% endif %}
{% if resources %}
Resources:
{% for r in resources %}
  - {{ r.label }}: {{ r.description }}
{% endfor %}
{% endif %}
{% if constraints %}
Constraints:
{% for c in constraints %}
  - {{ c.label }}: {{ c.description }}
{% endfor %}
{% endif %}
"""
{% endif %}

from autogen_agentchat.agents import AssistantAgent
{% if human_agents %}
from autogen_agentchat.agents import UserProxyAgent
{% endif %}

from autogen_agentchat.teams import {{ team_type }}

from autogen_agentchat.conditions import (

    MaxMessageTermination

)

from autogen_core.tools import FunctionTool

from autogen_ext.models.openai import (
    OpenAIChatCompletionClient
)

model_client = OpenAIChatCompletionClient(
    model="{{ model_name }}"
)

{% if environments %}
# ==================================================
# Environment Configuration
# ==================================================
{% for env in environments %}
# Environment: {{ env.label }} ({{ env.env_type }})
# {{ env.description }}
{% if env.configs %}
# Configs: {{ env.configs }}
{% endif %}
{% endfor %}
{% endif %}

# ==================================================
# Generated Tool Stubs
# ==================================================

{% for tool in tool_defs %}

def {{ tool.var_name }}_impl(
    query: str = ""
) -> str:
    """
    AgentO Tool:
    {{ tool.class_name }}

    Description:
    {{ tool.description }}
    """
    return (
        "Tool '{{ tool.var_name }}' "
        "is a generated stub and "
        "has not been implemented yet."
    )


{{ tool.var_name }} = FunctionTool(
    {{ tool.var_name }}_impl,
    description="""{{ tool.description | replace('"""', '\\"\\"\\"') }}"""
)

{% endfor %}

# ==================================================
# Agents
# ==================================================

{% for agent in project.agents %}

{{ agent.var_name }} = AssistantAgent(
    name="{{ agent.var_name if agent.var_name else agent.agent_id|replace('-', '_') }}",
    model_client=model_client,
    system_message="""
Role:
{{ agent.role | replace('"""', '\\"\\"\\"') }}

Goal:
{{ agent.goal | replace('"""', '\\"\\"\\"') }}

Background:
{{ agent.backstory | replace('"""', '\\"\\"\\"') }}
""",
{% if agent.tool_var_names %}
    tools=[
{% for tool_name in agent.tool_var_names %}
        {{ tool_name }},
{% endfor %}
    ],
{% endif %}
)

{% endfor %}

{% if human_agents %}
# ==================================================
# Human Agents (UserProxy)
# ==================================================

{% for h in human_agents %}
{{ h.var_name }} = UserProxyAgent(
    name="{{ h.var_name }}",
    description="""{{ h.role | replace('"""', '\\"\\"\\"') }}""",
)
{% endfor %}
{% endif %}

{% if not project.workflows %}
team = {{ team_type }}(
    participants=[
{% for agent in project.agents %}
        {{ agent.var_name }},
{% endfor %}
{% for h in human_agents %}
        {{ h.var_name }},
{% endfor %}
    ],
    termination_condition=MaxMessageTermination(
        max_messages=10
    )
)

TASK_PROMPT = """
{% for task in ordered_tasks %}

Task:
{{ task.description }}

Expected Output:
{{ task.expected_output }}

{% endfor %}
"""
{% endif %}