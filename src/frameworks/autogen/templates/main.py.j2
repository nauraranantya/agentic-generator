import asyncio

{% if resolved_steps %}
{% if project.agents or human_agents %}
from team import (
{% for agent in project.agents %}
    {{ agent.var_name }},
{% endfor %}
{% for h in human_agents %}
    {{ h.var_name }},
{% endfor %}
)
{% endif %}
{% else %}
from team import (
    team,
    TASK_PROMPT,
)
{% endif %}

from autogen_agentchat.conditions import (
    MaxMessageTermination,
)

INPUTS = {

{% for var in input_variables %}

    "{{ var.name }}":
{% if var.has_default %}
        "{{ var.default_value }}",
{% else %}
        "",
{% endif %}

{% endfor %}
}


async def main():
{% if resolved_steps %}
    try:
        # Step-by-step sequential execution
        {% for step in resolved_steps %}
        # ==================================================
        # Workflow Step: {{ step.task_var_name }}
        {% for next_step in step.next_task_vars %}
        # Workflow Edge: {{ step.task_var_name }} -> {{ next_step }}
        {% endfor %}
        # ==================================================
        print("\n" + "=" * 80)
        print("Executing step: {{ step.task_var_name }}")
        print("=" * 80)

        task_prompt = """{{ step.task_description | replace('"""', '\\"\\"\\"') }}"""
        # Execute via the assigned agent: {{ step.agent_var }}
        result = await {{ step.agent_var }}.run(task=task_prompt)

        # Print step output
        if hasattr(result, "messages") and result.messages:
            print(result.messages[-1].content)
        else:
            print(result)

        {% endfor %}
        print("\n" + "=" * 80)
        print("DONE")
        print("=" * 80)

    except Exception as e:
        print("\n" + "=" * 80)
        print("ERROR")
        print("=" * 80)
        print(type(e).__name__)
        print(str(e))

{% else %}
    {% if input_variables %}

    task = TASK_PROMPT.format(
        **INPUTS
    )

    {% else %}

    task = TASK_PROMPT

    {% endif %}

    print("\n" + "=" * 80)
    print("TASK")
    print("=" * 80)
    print(task)

    print("\n" + "=" * 80)
    print("STREAM")
    print("=" * 80)

    # Prevent infinite loops
    team._termination_condition = MaxMessageTermination(
        max_messages=20
    )

    try:

        async for msg in team.run_stream(
            task=task
        ):

            print("\n" + "-" * 60)
            print(type(msg).__name__)

            if hasattr(msg, "source"):
                print(f"SOURCE: {msg.source}")

            if hasattr(msg, "content"):
                print(msg.content)

            else:
                print(msg)

        print("\n" + "=" * 80)
        print("DONE")
        print("=" * 80)

    except Exception as e:

        print("\n" + "=" * 80)
        print("ERROR")
        print("=" * 80)

        print(type(e).__name__)
        print(str(e))
{% endif %}


if __name__ == "__main__":
    asyncio.run(main())