{# ────────────────────────────────────────────────────────
   Jinja2 Template: crew.py
   Generates a CrewAI crew class with @CrewBase decorator
   pattern, matching the official CrewAI project structure.
   ──────────────────────────────────────────────────────── #}
"""
Auto-generated CrewAI Crew: {{ crew_name }}

Source  : AgentO Knowledge Graph → SPARQL → Pydantic → Jinja2
Pipeline: 3-Layer Conversion Pipeline
{% if goals %}
Goals:
{% for g in goals %}
  - {{ g.label }}: {{ g.description }}
{% endfor %}
{% endif %}
{% if objectives %}
Objectives:
{% for o in objectives %}
  - {{ o.label }}: {{ o.description }}
{% endfor %}
{% endif %}
{% if human_agents %}
Human Agents:
{% for h in human_agents %}
  - {{ h.var_name }} ({{ h.role }})
{% endfor %}
{% endif %}
{% if environments %}
Environments:
{% for e in environments %}
  - {{ e.label }} ({{ e.env_type }}): {{ e.description }}
{% endfor %}
{% endif %}
{% if capabilities %}
Capabilities:
{% for c in capabilities %}
  - {{ c.label }}: {{ c.description }}
{% endfor %}
{% endif %}
{% if resources %}
Resources:
{% for r in resources %}
  - {{ r.label }}: {{ r.description }}
{% endfor %}
{% endif %}
{% if constraints %}
Constraints:
{% for c in constraints %}
  - {{ c.label }}: {{ c.description }}
{% endfor %}
{% endif %}
"""

{% if has_ollama_agents %}
from crewai import Agent, Crew, Process, Task, LLM
{% else %}
from crewai import Agent, Crew, Process, Task
{% endif %}
from crewai.project import CrewBase, agent, crew, task
{% if has_unknown_tools %}
from crewai.tools import tool
{% endif %}
{% if has_tools %}

{% for module, classes in import_groups.items() %}
from {{ module }} import {{ classes | join(', ') }}
{% endfor %}
{% endif %}

{% if has_tools %}
# ===========================================================
# Tool Instances
# ===========================================================
{% for ti in tool_imports %}
{% if ti.is_known %}
{{ ti.var_name }} = {{ ti.class_name }}({{ ti.args }})
{% else %}
# TODO: {{ ti.var_name }} — unknown tool class "{{ ti.class_name }}"
#   Implement as a custom BaseTool or replace with a crewai_tools equivalent.
@tool("{{ ti.class_name }}")
def {{ ti.var_name }}(*args, **kwargs) -> str:
    """{{ ti.description }}"""
    return "{{ ti.var_name }} result"

{% endif %}
{% endfor %}
{% endif %}

{% if has_ollama_agents %}
# ===========================================================
# Custom LLM
# ===========================================================
{% for entry in ollama_agents %}
{{ entry.var_name }}_llm = LLM(model="ollama/{{ entry.model_name }}")
{% endfor %}
{% endif %}


@CrewBase
class {{ crew_name }}:
    """{{ crew_name }} crew"""

    agents_config = 'config/agents.yaml'
    tasks_config = 'config/tasks.yaml'

    # ── Agents ──────────────────────────────────────────
{% for agent_item in agents %}

    @agent
    def {{ agent_item.var_name }}(self) -> Agent:
        return Agent(
            config=self.agents_config['{{ agent_item.var_name }}'],
{% if agent_tool_var_names[agent_item.var_name] %}
            tools=[{{ agent_tool_var_names[agent_item.var_name] | join(', ') }}],
{% endif %}
{% if agent_item.var_name in ollama_agent_names %}
            llm={{ agent_item.var_name }}_llm,
{% endif %}
{% if agent_allow_delegation[agent_item.var_name] is not none %}
            allow_delegation={{ agent_allow_delegation[agent_item.var_name] }},
{% endif %}
{% if agent_verbose[agent_item.var_name] is not none %}
            verbose={{ agent_verbose[agent_item.var_name] }},
{% endif %}
        )
{% endfor %}

    # ── Tasks ───────────────────────────────────────────
{% for task_item in tasks %}

    @task
    def {{ task_item.var_name }}(self) -> Task:
        return Task(
            config=self.tasks_config['{{ task_item.var_name }}'],
{% if task_item.agent_var_name %}
            agent=self.{{ task_item.agent_var_name }}(),
{% endif %}
{% if task_item.context_task_var_names %}
            context=[{% for ctx_name in task_item.context_task_var_names %}self.{{ ctx_name }}(){{ ", " if not loop.last }}{% endfor %}],
{% endif %}
{% if task_item.human_input %}
            human_input=True,
{% endif %}
        )
{% endfor %}

    # ── Crew ────────────────────────────────────────────

    @crew
    def crew(self) -> Crew:
        """Creates the {{ crew_name }}"""
        return Crew(
            agents=self.agents,
            tasks=self.tasks,
            process=Process.{{ process }},
            verbose=True,
        )
