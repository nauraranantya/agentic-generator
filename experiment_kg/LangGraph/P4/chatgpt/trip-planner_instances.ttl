# Execution time: 52.75 seconds
# Model used: gpt-5-mini
# Prompt: P4

# VALIDATION
# Check 1 (Completeness): PASS
# Check 2 (Workflow Integrity): PASS
# Check 3 (Structural Consistency): PASS
# Check 4 (Schema Compliance): PASS
#
# Issues / Assumptions:
# - Assumed a single LLM agent ("TripPlannerAgent") is responsible for UI-driven booking and recommendation tasks as implied by tool calls and thread usage in the source.
# - Assumed "book-accommodation" is the primary external tool; modeled it as :BookAccommodationTool with a :hasToolConfig entry.
# - Inferred a 4-step workflow (display -> select -> book -> confirm) to represent the UI flow in the code. Steps and mapping to tasks are explicit.
# - Preserved message/tool-call JSON structure and handler behavior from the source code within prompt instructions and task prompts for fidelity.
# - No new classes or properties were created; only individuals and existing properties/classes from the provided ontology were used.

@prefix : <http://www.w3id.org/agentic-ai/onto#> .
@prefix beam: <http://w3id.org/beam/core#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

####################
# Team / System
####################
:TripPlannerTeam rdf:type :Team ;
                 rdfs:label "Trip Planner Team" ;
                 :hasAgentMember :TripPlannerAgent ;
                 :hasWorkflowPattern :TripBookingPattern ;
                 :hasSystemConfig :TeamSystemConfig ;
                 dct:description "Frontend/back-end orchestration for trip planning UI components (accommodations & restaurants)." .

:TeamSystemConfig rdf:type :Config ;
                 :configKey "ui_framework" ;
                 :configValue "React (with LangGraph SDK integration)" ;
                 rdfs:label "Team system config" .

####################
# Agents
####################
:TripPlannerAgent rdf:type :LLMAgent ;
                  rdfs:label "Trip Planner Agent" ;
                  :agentID "trip-planner-agent-1" ;
                  :agentRole "booking-and-recommendation" ;
                  :agentPrompt :TripPlannerAgentPrompt ;
                  :hasKnowledge :TripDetailsKB ;
                  :useLanguageModel :ChatLanguageModel ;
                  :agentToolUsage :BookAccommodationTool ;
                  :hasAgentGoal :Goal_BookAccommodation ;
                  dct:description "Agent coordinating display, selection and booking of accommodations and recommending restaurants based on trip details." .

####################
# Human / User (represented as context, not a Team member)
####################
:EndUser rdf:type :HumanAgent ;
         rdfs:label "End User" ;
         dct:description "The human end user interacting via the UI; user actions (select, book) are reflected in the workflow and tool calls." .

####################
# Language Model
####################
:ChatLanguageModel rdf:type :LanguageModel ;
                   rdfs:label "Chat Language Model (placeholder)" ;
                   dct:description "Statistical language model used by the Trip Planner Agent (implementation placeholder for the runtime LLM)." .

####################
# Knowledge / Data
####################
:TripDetailsKB rdf:type :KnowledgeBase ;
               rdfs:label "Trip Details Knowledge Base" ;
               dct:description """
Trip details structure used across UI components and tool calls.
Example template:
{
  "location": "<city>",
  "startDate": "<YYYY-MM-DD>",
  "endDate": "<YYYY-MM-DD>",
  "numberOfGuests": <integer>
}
This KB represents the trip_details object passed through components and tool invocation payloads.
""" .

####################
# Tools & Capabilities
####################
:BookAccommodationTool rdf:type :Tool ;
                       rdfs:label "Book Accommodation Tool" ;
                       :hasToolConfig :BookToolConfig ;
                       :hasCapability :BookingCapability ;
                       dct:description "Tool invoked via thread.submit with name 'book-accommodation' that receives a JSON payload { accommodation, tripDetails } and processes booking orders." .

:BookToolConfig rdf:type :Config ;
                :configKey "tool_name" ;
                :configValue "book-accommodation" ;
                rdfs:label "Book Accommodation Tool Config" .

:BookingCapability rdf:type :Capability ;
                   rdfs:label "Booking Capability" ;
                   dct:description "Capability to accept accommodation + trip details payload and produce a booking/order resource." .

####################
# Tasks (from source code behaviors)
####################
:Task_DisplayAccommodations rdf:type :Task ;
                            rdfs:label "Display Accommodations" ;
                            :taskPrompt :Prompt_DisplayAccommodations ;
                            :performedByAgent :TripPlannerAgent ;
                            dct:description "Renders the list of accommodations (carousel). Data: accommodations array with id, name, image, rating, price, city." .

:Task_SelectAccommodation rdf:type :Task ;
                          rdfs:label "Select Accommodation" ;
                          :taskPrompt :Prompt_SelectAccommodation ;
                          :performedByAgent :TripPlannerAgent ;
                          dct:description "Handle user selection of a single accommodation item from the carousel/list; update selected state." .

:Task_BookAccommodation rdf:type :Task ;
                        rdfs:label "Book Accommodation" ;
                        :taskPrompt :Prompt_BookAccommodation ;
                        :performedByAgent :TripPlannerAgent ;
                        :performedBy :BookAccommodationTool ;
                        :producedResource :BookingOrderResource ;
                        dct:description "When user confirms booking, compose orderDetails { accommodation, tripDetails } and submit a 'tool' message with name 'book-accommodation' and content JSON. Also submits a follow-up human message indicating booking." .

:Task_ConfirmBooking rdf:type :Task ;
                     rdfs:label "Confirm Booking / Show Booked Accommodation" ;
                     :taskPrompt :Prompt_ConfirmBooking ;
                     :performedByAgent :TripPlannerAgent ;
                     dct:description "Display booked accommodation details (BookedAccommodation view) or success message when tool response is received and parsed." .

:Task_DisplayRestaurants rdf:type :Task ;
                         rdfs:label "Display Restaurants" ;
                         :taskPrompt :Prompt_DisplayRestaurants ;
                         :performedByAgent :TripPlannerAgent ;
                         dct:description "Renders list of restaurants for tripDetails.location; supports filters (cuisines), selection, and reserve actions (UI-only placeholder)." .

:Task_ReserveTable rdf:type :Task ;
                   rdfs:label "Reserve Table" ;
                   :taskPrompt :Prompt_ReserveTable ;
                   :performedByAgent :TripPlannerAgent ;
                   dct:description "UI action to reserve a table for selected restaurant; placeholder buttons 'Reserve a Table' and 'View Menu' trigger reservation intent." .

####################
# Prompts (capture logic, payloads, and important literals from the source)
####################
:TripPlannerAgentPrompt rdf:type :Prompt ;
                        rdfs:label "Agent main prompt (behavior spec)" ;
                        :promptInstruction """Agent behavior specification (derived from UI source):
- Display lists of accommodations and restaurants given tripDetails.
- Allow selection of accommodation or restaurant.
- When booking an accommodation: construct orderDetails = { accommodation, tripDetails } and submit a tool message with:
  {
    type: "tool",
    tool_call_id: <toolCallId>,
    id: "<DO_NOT_RENDER_ID_PREFIX><uuid>",
    name: "book-accommodation",
    content: JSON.stringify(orderDetails)
  }
- After tool invocation also submit a human message: "Booked <accommodation.name> for <tripDetails.numberOfGuests>."
- Listen for tool responses identified by toolCallId and parse JSON content to render booked accommodation.
""" ;
                        :promptContext "UI-driven agent acting within a LangGraph thread; uses tool-call pattern for side effects." .

:Prompt_DisplayAccommodations rdf:type :Prompt ;
                             rdfs:label "Prompt: Display Accommodations" ;
                             :promptInstruction "Render carousel of accommodations. Each item: { id, name, image, rating, price, city }. On click, set selected accommodation in UI state." .

:Prompt_SelectAccommodation rdf:type :Prompt ;
                           rdfs:label "Prompt: Select Accommodation" ;
                           :promptInstruction "User selects an accommodation; agent updates selectedAccommodation state and shows SelectedAccommodation view with details (dates, guests, total price calculation)." .

:Prompt_BookAccommodation rdf:type :Prompt ;
                         rdfs:label "Prompt: Book Accommodation" ;
                         :promptInstruction """On Book button click:
- Compose orderDetails = { accommodation: <selected>, tripDetails: <tripDetails> }.
- Call thread.submit with a message of type 'tool' named 'book-accommodation' and content JSON.stringify(orderDetails).
- Also emit a human message confirming booking.
Example content string (JSON):
{
  "accommodation": { "id": "...", "name": "...", "image": "...", "rating": 4.7, "price": 123, "city": "..." },
  "tripDetails": { "startDate": "YYYY-MM-DD", "endDate": "YYYY-MM-DD", "numberOfGuests": 2, "location": "..." }
}
""" .

:Prompt_ConfirmBooking rdf:type :Prompt ;
                       rdfs:label "Prompt: Confirm Booking" ;
                       :promptInstruction "Upon receiving tool response (toolResponse.content JSON), parse { accommodation, tripDetails } and render BookedAccommodation view showing address, dates, guests, and total price." .

:Prompt_DisplayRestaurants rdf:type :Prompt ;
                           rdfs:label "Prompt: Display Restaurants" ;
                           :promptInstruction "Render list of restaurants with filters by cuisine. Each restaurant item: { id, name, cuisine, priceRange, rating, distance, image, openingHours, popular }." .

:Prompt_ReserveTable rdf:type :Prompt ;
                     rdfs:label "Prompt: Reserve Table" ;
                     :promptInstruction "On 'Reserve a Table' click, trigger reservation intent for selected restaurant (placeholder UI action reserved for runtime integration)." .

####################
# Resources / Produced Outputs
####################
:BookingOrderResource rdf:type beam:Instance ;
                      rdfs:label "Booking Order Resource" ;
                      dct:description "Resource produced by the booking task: JSON orderDetails { accommodation, tripDetails } delivered to the back-end tool 'book-accommodation'." .

####################
# Goals & Objectives
####################
:Goal_BookAccommodation rdf:type :Goal ;
                       rdfs:label "Goal: Book accommodation for user trip" ;
                       dct:description "Primary goal assigned to the TripPlannerAgent: help user select and book accommodation matching tripDetails." .

####################
# Workflow Pattern & Steps
####################
:TripBookingPattern rdf:type :WorkflowPattern ;
                    rdfs:label "Trip Booking Workflow Pattern" ;
                    :hasWorkflowStep :Step1_DisplayList ,
                                      :Step2_SelectItem ,
                                      :Step3_BookItem ,
                                      :Step4_ConfirmBooking ;
                    dct:description "A workflow representing the UI flow: display -> select -> book -> confirm." .

:Step1_DisplayList rdf:type :StartStep ;
                   rdfs:label "Step 1: Display List" ;
                   :stepOrder "1"^^xsd:integer ;
                   :hasAssociatedTask :Task_DisplayAccommodations ;
                   :nextStep :Step2_SelectItem .

:Step2_SelectItem rdf:type :WorkflowStep ;
                 rdfs:label "Step 2: Select Item" ;
                 :stepOrder "2"^^xsd:integer ;
                 :hasAssociatedTask :Task_SelectAccommodation ;
                 :nextStep :Step3_BookItem .

:Step3_BookItem rdf:type :WorkflowStep ;
               rdfs:label "Step 3: Book Item" ;
               :stepOrder "3"^^xsd:integer ;
               :hasAssociatedTask :Task_BookAccommodation ;
               :nextStep :Step4_ConfirmBooking .

:Step4_ConfirmBooking rdf:type :EndStep ;
                     rdfs:label "Step 4: Confirm Booking" ;
                     :stepOrder "4"^^xsd:integer ;
                     :hasAssociatedTask :Task_ConfirmBooking .

####################
# Additional Workflow for Restaurants (connected via same pattern as sub-flow)
####################
:RestaurantsSubFlow rdf:type :WorkflowPattern ;
                    rdfs:label "Restaurant Browsing Subflow" ;
                    :hasWorkflowStep :StepR1_DisplayRestaurants ,
                                      :StepR2_SelectRestaurant ,
                                      :StepR3_ReserveTable ;
                    dct:description "Subflow for restaurant browsing and reservation actions in the UI." .

:StepR1_DisplayRestaurants rdf:type :StartStep ;
                           rdfs:label "Step R1: Display Restaurants" ;
                           :stepOrder "1"^^xsd:integer ;
                           :hasAssociatedTask :Task_DisplayRestaurants ;
                           :nextStep :StepR2_SelectRestaurant .

:StepR2_SelectRestaurant rdf:type :WorkflowStep ;
                         rdfs:label "Step R2: Select Restaurant" ;
                         :stepOrder "2"^^xsd:integer ;
                         :hasAssociatedTask :Task_DisplayRestaurants ;
                         :nextStep :StepR3_ReserveTable .

:StepR3_ReserveTable rdf:type :EndStep ;
                     rdfs:label "Step R3: Reserve Table" ;
                     :stepOrder "3"^^xsd:integer ;
                     :hasAssociatedTask :Task_ReserveTable .

####################
# Linking extra relations to ensure connectivity (no orphans)
####################
:TripBookingPattern :hasRelatedPattern :RestaurantsSubFlow .

# End of instance data.