# Execution time: 53.61 seconds
# Model used: gpt-5-mini
# Prompt: P5

# Framework: LangGraph

# Issues / Assumptions:
# - Assumed LangGraph-based usage due to import of @langchain/langgraph-sdk and thread.tool call patterns.
# - No explicit agents or models found in source; created a single LLM-backed agent (:tradeAgent) to represent the system agent that invokes the "buy-stock" tool.
# - Created a default :LanguageModel (:lm_default) because no explicit model configuration was present.
# - Introduced a small three-step workflow (Open UI → Execute Purchase → Confirm) to capture the UI-driven buy flow observed in the code; created synthetic tasks for the steps to satisfy the workflow checklist.
# - Created a :Tool individual for the "buy-stock" tool call observed in thread.submit and provided capability and a minimal config.

@prefix : <http://www.w3id.org/agentic-ai/onto#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix beam: <http://w3id.org/beam/core#> .

# Agent (LLM-backed) representing the system actor that invokes tools from the UI
:tradeAgent rdf:type :LLMAgent ;
            :agentID "trade_agent" ;
            :agentRole "trading_assistant" ;
            :agentPrompt :prompt_trade_agent ;
            :useLanguageModel :lm_default ;
            :agentToolUsage :buyStockTool ;
            dcterms:description "LLM-backed agent that assists with portfolio display and executes trade requests from the UI." .

# Agent prompt / system instruction for the agent
:prompt_trade_agent rdf:type :Prompt ;
                    :promptInstruction "You are a trading assistant. Help users view portfolio information and execute stock trades. When executing a trade, call the 'buy-stock' tool with a JSON payload containing purchaseDetails: { ticker, quantity, price } and then confirm the purchase to the user." .

# Default Language Model (created because source did not specify a concrete model)
:lm_default rdf:type :LanguageModel ;
            dcterms:title "default" ;
            dcterms:description "Default language model placeholder (no explicit model configured in source code)." .

# Tool observed in the UI code (thread.submit with name 'buy-stock')
:buyStockTool rdf:type :Tool ;
             dcterms:title "buy-stock" ;
             dcterms:description "Executes stock purchase orders when invoked by the UI. Expects a JSON content with purchaseDetails { ticker, quantity, price }." ;
             :hasCapability :capExecuteBuy ;
             :hasToolConfig :buyStockToolConfig .

:capExecuteBuy rdf:type :Capability ;
               dcterms:description "Execute market buy orders for a specified ticker and quantity at the provided price." .

:buyStockToolConfig rdf:type :Config ;
                    :configKey "id" ;
                    :configValue "buy-stock" .

# Tasks representing the steps in the buy flow (synthetic tasks to match workflow)
:OpenBuyUITask rdf:type :Task ;
               :performedByAgent :tradeAgent ;
               :taskPrompt :prompt_open_ui ;
               dcterms:title "Open Buy UI Task" ;
               dcterms:description "Prepare and present the buy stock UI to the user." .

:prompt_open_ui rdf:type :Prompt ;
                :promptInstruction "Open the buy stock user interface for the specified ticker and prefill price information. Expected output: UI displayed and ready for user input." ;
                :promptOutputIndicator "ui_opened" .

:ExecutePurchaseTask rdf:type :Task ;
                     :performedByAgent :tradeAgent ;
                     :taskPrompt :prompt_buy_stock ;
                     dcterms:title "Execute Purchase Task" ;
                     dcterms:description "Execute the purchase by invoking the buy-stock tool with purchaseDetails." .

:prompt_buy_stock rdf:type :Prompt ;
                 :promptInstruction "Invoke the 'buy-stock' tool with JSON: { purchaseDetails: { ticker: <string>, quantity: <integer>, price: <number> } }. Expect the tool to return a confirmation payload." ;
                 :promptOutputIndicator "purchaseDetails object with fields: ticker (string), quantity (integer), price (number)" .

:ConfirmPurchaseTask rdf:type :Task ;
                     :performedByAgent :tradeAgent ;
                     :taskPrompt :prompt_confirm_purchase ;
                     dcterms:title "Confirm Purchase Task" ;
                     dcterms:description "Display purchase confirmation to the user including executed quantity and price." .

:prompt_confirm_purchase rdf:type :Prompt ;
                        :promptInstruction "Present the purchase confirmation message to the user, showing ticker, quantity, price, and total cost. Expected output: confirmation message shown in UI." ;
                        :promptOutputIndicator "confirmation_message" .

# Workflow pattern capturing the buy-stock flow
:BuyStockWorkflow rdf:type :WorkflowPattern ;
                  dcterms:title "Buy Stock Workflow" ;
                  :hasWorkflowStep :step1Start , :step2Purchase , :step3End ;
                  dcterms:description "A simple three-step flow: open UI, execute purchase, confirm purchase." .

# Workflow steps (Start, intermediate, End)
:step1Start rdf:type :StartStep , :WorkflowStep ;
            :stepOrder "1"^^xsd:integer ;
            :hasAssociatedTask :OpenBuyUITask ;
            dcterms:title "Start - Open Buy UI" .

:step2Purchase rdf:type :WorkflowStep ;
               :stepOrder "2"^^xsd:integer ;
               :hasAssociatedTask :ExecutePurchaseTask ;
               dcterms:title "Execute Purchase Step" .

:step3End rdf:type :EndStep , :WorkflowStep ;
          :stepOrder "3"^^xsd:integer ;
          :hasAssociatedTask :ConfirmPurchaseTask ;
          dcterms:title "End - Confirm Purchase" .

# Step ordering / transitions
:step1Start :nextStep :step2Purchase .
:step2Purchase :nextStep :step3End .

# Team / system grouping
:TradingSystem rdf:type :Team ;
               dcterms:title "Trading System" ;
               :hasAgentMember :tradeAgent ;
               :hasWorkflowPattern :BuyStockWorkflow ;
               :hasTeamGoal :goal_manage_portfolio ;
               dcterms:description "Frontend trading system that displays portfolio data and enables trade execution." .

:goal_manage_portfolio rdf:type :Goal ;
                       dcterms:title "Manage Portfolio" ;
                       dcterms:description "Provide portfolio overview and enable executing trades via the UI." .