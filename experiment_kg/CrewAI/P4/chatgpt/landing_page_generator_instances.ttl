# Execution time: 82.50 seconds
# Model used: gpt-5-mini
# Prompt: P4

# VALIDATION
# Check 1 (Completeness): PASS
# Check 2 (Workflow Integrity): PASS
# Check 3 (Structural Consistency): PASS
# Check 4 (Schema Compliance): PASS
# Issues / Assumptions:
# - No issues detected. Assumptions recorded: senior_react_engineer is modeled as a single :LLMAgent used across crews; Task descriptions and agent configs preserved as :Config individuals; prompts preserved as :Prompt individuals (promptInstruction used). FileManagementToolkit tools modeled as individual :Tool instances (read_file, list_directory). WorkflowPattern models the overall pipeline used by the LandingPageCrew.

@prefix : <http://www.w3id.org/agentic-ai/onto#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.w3id.org/agentic-ai/onto#> .

#################################################################
# Instances describing the "AI Crew for Landing Pages" solution
#################################################################

# Language models
:lm_OpenAI_GPT4 rdf:type :LanguageModel ;
    rdfs:label "OpenAI GPT-4" ;
    <http://purl.org/dc/terms/description> "Default LLM used by the CrewAI-based agents; mentioned as default in README and main execution notes." .

:lm_OpenAI_GPT35 rdf:type :LanguageModel ;
    rdfs:label "OpenAI GPT-3.5" ;
    <http://purl.org/dc/terms/description> "Alternative LLM option described in README (example instantiation for GPT-3.5)." .

:lm_Ollama_agent rdf:type :LanguageModel ;
    rdfs:label "Ollama (local) agent model" ;
    <http://purl.org/dc/terms/description> "Local model option described in README for using Ollama; included as an available model option." .

# Tools (as Tool individuals)
:tool_SearchTools rdf:type :Tool ;
    rdfs:label "SearchTools.search_internet" ;
    <http://purl.org/dc/terms/description> "Tool that calls Serper API to search the internet and returns formatted results." .

:tool_BrowserTools rdf:type :Tool ;
    rdfs:label "BrowserTools.scrape_and_summarize_website" ;
    <http://purl.org/dc/terms/description> "Tool that scrapes website content via browserless API, partitions HTML, and summarizes via an internal Task." .

:tool_FileTools_WriteFile rdf:type :Tool ;
    rdfs:label "FileTools.write_file" ;
    <http://purl.org/dc/terms/description> "Tool that writes content to the safe ./workdir filesystem; input is a pipe-separated path|content string." .

:tool_TemplateTools_Learn rdf:type :Tool ;
    rdfs:label "TemplateTools.learn_landing_page_options" ;
    <http://purl.org/dc/terms/description> "Tool that reads config/templates.json and returns available templates." .

:tool_TemplateTools_Copy rdf:type :Tool ;
    rdfs:label "TemplateTools.copy_landing_page_template_to_project_folder" ;
    <http://purl.org/dc/terms/description> "Tool that copies a named template folder from ./templates into ./workdir safely." .

:tool_FileMgmt_read_file rdf:type :Tool ;
    rdfs:label "FileManagementToolkit.read_file" ;
    <http://purl.org/dc/terms/description> "Toolkit-provided read_file tool available via FileManagementToolkit.get_tools()." .

:tool_FileMgmt_list_directory rdf:type :Tool ;
    rdfs:label "FileManagementToolkit.list_directory" ;
    <http://purl.org/dc/terms/description> "Toolkit-provided list_directory tool available via FileManagementToolkit.get_tools()." .

#################################################################
# Agents (LLMAgent individuals)
#################################################################

:agent_SeniorIdeaAnalyst rdf:type :LLMAgent ;
    :agentID "senior_idea_analyst" ;
    :agentRole "Senior Idea Analyst" ;
    :agentPrompt :prompt_agent_senior_idea_analyst ;
    :hasAgentConfig :config_agent_senior_idea_analyst_role , :config_agent_senior_idea_analyst_goal , :config_agent_senior_idea_analyst_backstory ;
    :agentToolUsage :tool_SearchTools , :tool_BrowserTools ;
    :useLanguageModel :lm_OpenAI_GPT4 ;
    <http://purl.org/dc/terms/description> "Agent defined in config/agents.yaml and instantiated in ExpandIdeaCrew.senior_idea_analyst_agent." .

:agent_SeniorStrategist rdf:type :LLMAgent ;
    :agentID "senior_strategist" ;
    :agentRole "Senior Communications Strategist" ;
    :agentPrompt :prompt_agent_senior_strategist ;
    :hasAgentConfig :config_agent_senior_strategist_role , :config_agent_senior_strategist_goal , :config_agent_senior_strategist_backstory ;
    :agentToolUsage :tool_SearchTools , :tool_BrowserTools ;
    :useLanguageModel :lm_OpenAI_GPT4 ;
    <http://purl.org/dc/terms/description> "Agent defined in config/agents.yaml and instantiated in ExpandIdeaCrew.senior_strategist_agent." .

:agent_SeniorReactEngineer rdf:type :LLMAgent ;
    :agentID "senior_react_engineer" ;
    :agentRole "Senior React Engineer" ;
    :agentPrompt :prompt_agent_senior_react_engineer ;
    :hasAgentConfig :config_agent_senior_react_engineer_role , :config_agent_senior_react_engineer_goal , :config_agent_senior_react_engineer_backstory ;
    :agentToolUsage :tool_SearchTools , :tool_BrowserTools , :tool_TemplateTools_Learn , :tool_TemplateTools_Copy , :tool_FileTools_WriteFile , :tool_FileMgmt_read_file , :tool_FileMgmt_list_directory ;
    :useLanguageModel :lm_OpenAI_GPT4 ;
    <http://purl.org/dc/terms/description> "Agent defined in config/agents.yaml and instantiated in ChooseTemplateCrew and CreateContentCrew (same agent instance reused across crews)." .

:agent_SeniorContentEditor rdf:type :LLMAgent ;
    :agentID "senior_content_editor" ;
    :agentRole "Senior Content Editor" ;
    :agentPrompt :prompt_agent_senior_content_editor ;
    :hasAgentConfig :config_agent_senior_content_editor_role , :config_agent_senior_content_editor_goal , :config_agent_senior_content_editor_backstory ;
    :agentToolUsage ; # intentionally no tools (empty) .
    :useLanguageModel :lm_OpenAI_GPT4 ;
    <http://purl.org/dc/terms/description> "Agent defined in config/agents.yaml and instantiated in CreateContentCrew.senior_content_editor_agent." .

#################################################################
# Agent prompt individuals (each agent has a Prompt with promptInstruction)
#################################################################

:prompt_agent_senior_idea_analyst rdf:type :Prompt ;
    :promptInstruction """Recognized as a thought leader, I thrive on refining concepts into campaigns that resonate with audiences. Role: Senior Idea Analyst. Goal: Understand and expand upon the essence of ideas, make sure they are great and focus on real pain points others could benefit from.""" .

:prompt_agent_senior_strategist rdf:type :Prompt ;
    :promptInstruction """A narrative craftsman for top-tier launches, I reveal the 'why' behind projects, aligning with visions and speaking to audiences. Role: Senior Communications Strategist. Goal: Craft compelling stories using the Golden Circle method to captivate and engage people around an idea.""" .

:prompt_agent_senior_react_engineer rdf:type :Prompt ;
    :promptInstruction """A coding virtuoso and design enthusiast, expert in Tailwind, you're known for crafting beautiful websites that provide seamless user experiences. Role: Senior React Engineer. Goal: Build an intuitive, aesthetically pleasing, and high-converting landing page.""" .

:prompt_agent_senior_content_editor rdf:type :Prompt ;
    :promptInstruction """With a keen eye for detail and a passion for storytelling, you have refined content for leading brands, turning bland text into engaging stories. Role: Senior Content Editor. Goal: Ensure the landing page content is clear, concise, and captivating.""" .

