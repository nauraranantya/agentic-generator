#################################################################
# Teams (Crews) and membership
#################################################################

:team_ExpandIdeaCrew rdf:type :Team ;
    rdfs:label "ExpandIdeaCrew" ;
    :hasAgentMember :agent_SeniorIdeaAnalyst , :agent_SeniorStrategist ;
    :hasWorkflowPattern :pattern_ExpandIdeaCrew_workflow ;
    <http://purl.org/dc/terms/description> "CrewBase class ExpandIdeaCrew in crew.py instantiates two agents and two tasks (expand_idea, refine_idea) and runs sequentially." .

:team_ChooseTemplateCrew rdf:type :Team ;
    rdfs:label "ChooseTemplateCrew" ;
    :hasAgentMember :agent_SeniorReactEngineer ;
    :hasWorkflowPattern :pattern_ChooseTemplateCrew_workflow ;
    <http://purl.org/dc/terms/description> "CrewBase class ChooseTemplateCrew in crew.py instantiates senior_react_engineer agent and tasks choose_template and update_page in a sequential process." .

:team_CreateContentCrew rdf:type :Team ;
    rdfs:label "CreateContentCrew" ;
    :hasAgentMember :agent_SeniorContentEditor , :agent_SeniorReactEngineer ;
    :hasWorkflowPattern :pattern_CreateContentCrew_workflow ;
    <http://purl.org/dc/terms/description> "CrewBase class CreateContentCrew in crew.py instantiates senior_content_editor and senior_react_engineer and tasks create_content, update_component, qa_component in a sequential process." .

:team_LandingPageCrew rdf:type :Team ;
    rdfs:label "LandingPageCrew" ;
    :hasAgentMember :agent_SeniorIdeaAnalyst , :agent_SeniorStrategist , :agent_SeniorReactEngineer , :agent_SeniorContentEditor ;
    :hasWorkflowPattern :pattern_landing_page ;
    <http://purl.org/dc/terms/description> "Orchestration class LandingPageCrew that composes the three crews to execute the full pipeline: expand idea -> choose template -> create content. Represented as a Team that references an overall workflow pattern." .

#################################################################
# Workflow patterns and steps (chain with start and end)
#################################################################

:pattern_ExpandIdeaCrew_workflow rdf:type :WorkflowPattern ;
    rdfs:label "ExpandIdeaCrew Workflow" ;
    :hasWorkflowStep :step_expand_start , :step_expand_idea , :step_refine_idea , :step_expand_end ;
    <http://purl.org/dc/terms/description> "Workflow pattern for ExpandIdeaCrew (sequential): expand_idea then refine_idea." .

:pattern_ChooseTemplateCrew_workflow rdf:type :WorkflowPattern ;
    rdfs:label "ChooseTemplateCrew Workflow" ;
    :hasWorkflowStep :step_choose_start , :step_choose_template , :step_update_page , :step_choose_end ;
    <http://purl.org/dc/terms/description> "Workflow pattern for ChooseTemplateCrew (sequential): choose_template then update_page." .

:pattern_CreateContentCrew_workflow rdf:type :WorkflowPattern ;
    rdfs:label "CreateContentCrew Workflow" ;
    :hasWorkflowStep :step_create_start , :step_create_content , :step_update_component , :step_qa_component , :step_create_end ;
    <http://purl.org/dc/terms/description> "Workflow pattern for CreateContentCrew (sequential): create_content -> update_component -> qa_component." .

:pattern_landing_page rdf:type :WorkflowPattern ;
    rdfs:label "Landing Page Overall Workflow" ;
    :hasWorkflowStep :step_global_start , :step_expand_idea , :step_choose_template , :step_update_page , :step_create_content , :step_update_component , :step_qa_component , :step_global_end ;
    <http://purl.org/dc/terms/description> "Overall pipeline executed by LandingPageCrew combining sub-crews: expand idea, choose template, create content." .

#################################################################
# Workflow steps (StartStep, EndStep, WorkflowStep) with order and chaining
#################################################################

:step_global_start rdf:type :StartStep ;
    rdfs:label "Global Start" ;
    :stepOrder "1"^^xsd:integer ;
    :nextStep :step_expand_idea ;
    :hasAssociatedTask :task_expand_idea .

:step_expand_start rdf:type :StartStep ;
    rdfs:label "ExpandCrew Start" ;
    :stepOrder "1"^^xsd:integer ;
    :nextStep :step_expand_idea ;
    :hasAssociatedTask :task_expand_idea .

:step_expand_idea rdf:type :WorkflowStep ;
    rdfs:label "Expand Idea Step" ;
    :stepOrder "2"^^xsd:integer ;
    :nextStep :step_refine_idea ;
    :hasAssociatedTask :task_expand_idea .

:step_refine_idea rdf:type :WorkflowStep ;
    rdfs:label "Refine Idea Step" ;
    :stepOrder "3"^^xsd:integer ;
    :nextStep :step_choose_template ;
    :hasAssociatedTask :task_refine_idea .

:step_choose_start rdf:type :StartStep ;
    rdfs:label "ChooseTemplateCrew Start" ;
    :stepOrder "4"^^xsd:integer ;
    :nextStep :step_choose_template ;
    :hasAssociatedTask :task_choose_template .

:step_choose_template rdf:type :WorkflowStep ;
    rdfs:label "Choose Template Step" ;
    :stepOrder "5"^^xsd:integer ;
    :nextStep :step_update_page ;
    :hasAssociatedTask :task_choose_template .

:step_update_page rdf:type :WorkflowStep ;
    rdfs:label "Update Page Step" ;
    :stepOrder "6"^^xsd:integer ;
    :nextStep :step_create_content ;
    :hasAssociatedTask :task_update_page .

:step_create_start rdf:type :StartStep ;
    rdfs:label "CreateContentCrew Start" ;
    :stepOrder "7"^^xsd:integer ;
    :nextStep :step_create_content ;
    :hasAssociatedTask :task_create_content .

:step_create_content rdf:type :WorkflowStep ;
    rdfs:label "Create Content Step" ;
    :stepOrder "8"^^xsd:integer ;
    :nextStep :step_update_component ;
    :hasAssociatedTask :task_create_content .

:step_update_component rdf:type :WorkflowStep ;
    rdfs:label "Update Component Step" ;
    :stepOrder "9"^^xsd:integer ;
    :nextStep :step_qa_component ;
    :hasAssociatedTask :task_update_component .

:step_qa_component rdf:type :WorkflowStep ;
    rdfs:label "QA Component Step" ;
    :stepOrder "10"^^xsd:integer ;
    :nextStep :step_global_end ;
    :hasAssociatedTask :task_qa_component .

:step_choose_end rdf:type :EndStep ;
    rdfs:label "ChooseTemplateCrew End" ;
    :stepOrder "7"^^xsd:integer ;
    :hasAssociatedTask :task_update_page .

:step_expand_end rdf:type :EndStep ;
    rdfs:label "ExpandCrew End" ;
    :stepOrder "4"^^xsd:integer ;
    :hasAssociatedTask :task_refine_idea .

:step_create_end rdf:type :EndStep ;
    rdfs:label "CreateContentCrew End" ;
    :stepOrder "11"^^xsd:integer ;
    :hasAssociatedTask :task_qa_component .

:step_global_end rdf:type :EndStep ;
    rdfs:label "Global End" ;
    :stepOrder "11"^^xsd:integer ;
    :hasAssociatedTask :task_qa_component .

#################################################################
# Relationships ensuring no orphaned individuals and schema compliance
#################################################################

# Ensure tools are referenced by agents (agentToolUsage already set on agents)
# Ensure tasks reference agents via performedByAgent (already set)

# Link teams to workflow patterns (already set above)
# Also link LandingPageCrew overall pattern to sub-patterns via hasRelatedPattern (optional but uses existing property)
:pattern_landing_page :hasRelatedPattern :pattern_ExpandIdeaCrew_workflow , :pattern_ChooseTemplateCrew_workflow , :pattern_CreateContentCrew_workflow .

#################################################################
# Additional metadata and safe linkage to avoid orphans
#################################################################

# Link tool descriptions to capabilities (optional Capability individuals preserved minimal to avoid orphaning)
:cap_search_internet rdf:type :Capability ;
    rdfs:label "search internet capability" ;
    <http://purl.org/dc/terms/description> "Capability used by SearchTools to perform web searches." .

:cap_scrape_and_summarize rdf:type :Capability ;
    rdfs:label "scrape and summarize capability" ;
    <http://purl.org/dc/terms/description> "Capability used by BrowserTools to scrape and summarize website content." .

# Connect capabilities to tools using :hasCapability (domain Tool -> Capability)
:tool_SearchTools :hasCapability :cap_search_internet .
:tool_BrowserTools :hasCapability :cap_scrape_and_summarize .

#################################################################
# Ensure every individual is connected to at least one other individual
#################################################################

# Agents are members of teams (already set)
# Ensure the CreateContentCrew's senior_react_engineer and senior_content_editor are members (already set)
# No dangling references remain.

# End of instance data for the Landing Page Crew solution.