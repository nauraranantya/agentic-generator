# Execution time: 53.85 seconds
# Model used: gpt-5-mini
# Prompt: P4

# VALIDATION
# Check 1 (Completeness): PASS
# Check 2 (Workflow Integrity): PASS
# Check 3 (Structural Consistency): PASS
# Check 4 (Schema Compliance): PASS
#
# Issues / Assumptions:
# - Mapped the Crew instance `blog_crew` to a :Team individual (:BlogCrew).
# - Mapped agent role/goal/backstory into agent-level :Prompt individuals to preserve fidelity.
# - The EndStep is associated with tasks (all three) to ensure every workflow step has at least one associated task (requirement).
# - All configuration entries for the Weaviate tool are modeled as separate :Config individuals (one key/value per Config).

@prefix : <http://www.w3id.org/agentic-ai/onto#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix beam: <http://w3id.org/beam/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix dct: <http://purl.org/dc/terms/> .

#################################################################
# Instances for Tools
#################################################################

:WeaviateVectorSearchTool rdf:type :Tool ;
    dct:title "WeaviateVectorSearchTool" ;
    rdfs:comment "Tool wrapper around Weaviate vector search used by agents in the solution." ;
    :hasToolConfig :WeaviateToolConfig_collection_name ,
                   :WeaviateToolConfig_limit ,
                   :WeaviateToolConfig_cluster_url ,
                   :WeaviateToolConfig_api_key ;
    :resourceUsage :WeaviateBlogChunk_Resource .

:SerperDevTool rdf:type :Tool ;
    dct:title "SerperDevTool" ;
    rdfs:comment "Web search tool (Serper.dev) used by agents for internet search." .

#################################################################
# Weaviate Resource Instance
#################################################################

:WeaviateBlogChunk_Resource rdf:type beam:Instance ;
    dct:title "WeaviateBlogChunk" ;
    dct:description "Weaviate collection used as a retrieval source by the WeaviateVectorSearchTool (collection_name 'WeaviateBlogChunk')." .

#################################################################
# Tool Configs (each Config has configKey and configValue)
#################################################################

:WeaviateToolConfig_collection_name rdf:type :Config ;
    :configKey "collection_name" ;
    :configValue "WeaviateBlogChunk" .

:WeaviateToolConfig_limit rdf:type :Config ;
    :configKey "limit" ;
    :configValue "4" .

:WeaviateToolConfig_cluster_url rdf:type :Config ;
    :configKey "weaviate_cluster_url" ;
    :configValue "WCD_CLUSTER_URL (from environment)" .

:WeaviateToolConfig_api_key rdf:type :Config ;
    :configKey "weaviate_api_key" ;
    :configValue "WCD_CLUSTER_KEY (from environment)" .

#################################################################
# Language Model Instances
#################################################################

:gpt4o_mini_model rdf:type :LanguageModel ;
    dct:title "gpt-4o-mini" ;
    dct:description "Language model specified for the agents in the source code." .

#################################################################
# Agents (LLMAgent) and their Prompts/Configs
#################################################################

:BiomedicalMarketingAgent rdf:type :LLMAgent ;
    :agentID "biomedical_marketing_agent_001" ;
    :agentRole "Industry researcher focused on biomedical trends and their applications in AI" ;
    :agentPrompt :Prompt_BiomedicalAgent ;
    :agentToolUsage :SerperDevTool , :WeaviateVectorSearchTool ;
    :useLanguageModel :gpt4o_mini_model ;
    rdfs:label "Biomedical Marketing Agent" .

:HealthcareMarketingAgent rdf:type :LLMAgent ;
    :agentID "healthcare_marketing_agent_001" ;
    :agentRole "AI-savvy marketer specializing in healthcare systems, digital health, and patient engagement." ;
    :agentPrompt :Prompt_HealthcareAgent ;
    :agentToolUsage :SerperDevTool , :WeaviateVectorSearchTool ;
    :useLanguageModel :gpt4o_mini_model ;
    rdfs:label "Healthcare Marketing Agent" .

:FinancialMarketingAgent rdf:type :LLMAgent ;
    :agentID "financial_marketing_agent_001" ;
    :agentRole "Insight analyst exploring innovations in finance, wealth tech, and regulatory tech" ;
    :agentPrompt :Prompt_FinancialAgent ;
    :agentToolUsage :SerperDevTool , :WeaviateVectorSearchTool ;
    :useLanguageModel :gpt4o_mini_model ;
    rdfs:label "Financial Marketing Agent" .

#################################################################
# Agent Prompt Individuals (capture role, goal, backstory)
#################################################################

:Prompt_BiomedicalAgent rdf:type :Prompt ;
    :promptInstruction """
role: Industry researcher focused on biomedical trends and their applications in AI
goal: Continuously track the latest biomedical advancements and identify how Weaviate’s features can support AI applications in biomedical research, diagnostics, and personalized medicine.
backstory: As a former biomedical product marketer turned AI strategist, you understand the complex language and regulatory landscape of biomedical innovation. With a keen eye on genomics, clinical research, and medical devices, it now leverages LLMs and vector search to explore how Weaviate’s capabilities can streamline scientific discovery and patient-centric campaigns.
tools: SerperDevTool (web search), WeaviateVectorSearchTool (vector search)
llm: gpt-4o-mini
""" ;
    :promptContext "Agent-level guidance and context for autonomous research and analysis." .

:Prompt_HealthcareAgent rdf:type :Prompt ;
    :promptInstruction """
role: AI-savvy marketer specializing in healthcare systems, digital health, and patient engagement.
goal: Stay updated on healthcare policy shifts, digital health trends, and explore how Weaviate’s features can optimize workflows in hospital systems, EHR integration, and health communication.
backstory: Rooted in public health communications, this agent has evolved into a digital health consultant. You focus on how retrieval-augmented generation (RAG), semantic search, and hybrid models can be applied to solve healthcare-specific challenges—from patient triage to clinical support systems.
tools: SerperDevTool (web search), WeaviateVectorSearchTool (vector search)
llm: gpt-4o-mini
""" ;
    :promptContext "Agent-level guidance and context for healthcare-focused research." .

:Prompt_FinancialAgent rdf:type :Prompt ;
    :promptInstruction """
role: Insight analyst exploring innovations in finance, wealth tech, and regulatory tech
goal: Monitor financial sector trends including AI in trading, compliance automation, and client advisory, and assess how Weaviate’s tools can enable cutting-edge financial applications.
backstory: With experience at a fintech startup and a background in capital markets, this agent specializes in using structured + unstructured data to surface insights for analysts and advisors. Now, it’s looking into how vector databases and LLMs can automate tasks like fraud detection, investor personalization, and market research.
tools: SerperDevTool (web search), WeaviateVectorSearchTool (vector search)
llm: gpt-4o-mini
""" ;
    :promptContext "Agent-level guidance and context for financial-sector research." .

#################################################################
# Tasks and Task Prompts
#################################################################

:Task_BiomedicalResearch rdf:type :Task ;
    <http://purl.org/dc/terms/description> """
Conduct a thorough research about {weaviate_feature}
Make sure you find any interesting and relevant information using the web and Weaviate blogs.
""" ;
    :taskPrompt :Prompt_BiomedicalTask ;
    :performedByAgent :BiomedicalMarketingAgent ;
    rdfs:label "Biomedical research task" .

:Prompt_BiomedicalTask rdf:type :Prompt ;
    :promptInstruction """
Conduct a thorough research about {weaviate_feature}
Make sure you find any interesting and relevant information using the web and Weaviate blogs.
""" ;
    :promptOutputIndicator """
Write an industry specific analysis of why this Weaviate feature would be useful for your industry of expertise.
""" .

:Task_HealthcareResearch rdf:type :Task ;
    <http://purl.org/dc/terms/description> """
Conduct a thorough research about {weaviate_feature}
Make sure you find any interesting and relevant information using the web and Weaviate blogs.
""" ;
    :taskPrompt :Prompt_HealthcareTask ;
    :performedByAgent :HealthcareMarketingAgent ;
    rdfs:label "Healthcare research task" .

:Prompt_HealthcareTask rdf:type :Prompt ;
    :promptInstruction """
Conduct a thorough research about {weaviate_feature}
Make sure you find any interesting and relevant information using the web and Weaviate blogs.
""" ;
    :promptOutputIndicator """
Write an industry specific analysis of why this Weaviate feature would be useful for your industry of expertise.
""" .

:Task_FinancialResearch rdf:type :Task ;
    <http://purl.org/dc/terms/description> """
Conduct a thorough research about {weaviate_feature}
Make sure you find any interesting and relevant information using the web and Weaviate blogs.
""" ;
    :taskPrompt :Prompt_FinancialTask ;
    :performedByAgent :FinancialMarketingAgent ;
    rdfs:label "Financial research task" .

:Prompt_FinancialTask rdf:type :Prompt ;
    :promptInstruction """
Conduct a thorough research about {weaviate_feature}
Make sure you find any interesting and relevant information using the web and Weaviate blogs.
""" ;
    :promptOutputIndicator """
Write an industry specific analysis of why this Weaviate feature would be useful for your industry of expertise.
""" .

#################################################################
# Team / Crew Representation
#################################################################

:BlogCrew rdf:type :Team ;
    rdfs:label "blog_crew (Crew mapped to Team)" ;
    :hasAgentMember :BiomedicalMarketingAgent ,
                    :HealthcareMarketingAgent ,
                    :FinancialMarketingAgent ;
    :hasWorkflowPattern :BlogWorkflowPattern .

#################################################################
# Workflow Pattern and Steps (Start -> Step1 -> Step2 -> End)
#################################################################

:BlogWorkflowPattern rdf:type :WorkflowPattern ;
    rdfs:label "Blog research workflow pattern used by the crew" ;
    :hasWorkflowStep :Blog_StartStep ,
                     :Blog_Step1 ,
                     :Blog_Step2 ,
                     :Blog_EndStep .

:Blog_StartStep rdf:type :StartStep ;
    rdfs:label "Start step: kickoff for each feature" ;
    :stepOrder "1"^^xsd:integer ;
    :nextStep :Blog_Step1 ;
    :hasAssociatedTask :Task_BiomedicalResearch .

:Blog_Step1 rdf:type :WorkflowStep ;
    rdfs:label "Step 1: healthcare/second agent research" ;
    :stepOrder "2"^^xsd:integer ;
    :nextStep :Blog_Step2 ;
    :hasAssociatedTask :Task_HealthcareResearch .

:Blog_Step2 rdf:type :WorkflowStep ;
    rdfs:label "Step 2: financial/third agent research" ;
    :stepOrder "3"^^xsd:integer ;
    :nextStep :Blog_EndStep ;
    :hasAssociatedTask :Task_FinancialResearch .

:Blog_EndStep rdf:type :EndStep ;
    rdfs:label "End step: aggregate and finalize outputs" ;
    :stepOrder "4"^^xsd:integer ;
    :hasAssociatedTask :Task_BiomedicalResearch ,
                       :Task_HealthcareResearch ,
                       :Task_FinancialResearch .

#################################################################
# Additional Linkages and Metadata
#################################################################

# Link tools to agents explicitly using agentToolUsage (agents already list tool usage; this creates the inverse relation usage)
:BiomedicalMarketingAgent :agentToolUsage :WeaviateVectorSearchTool , :SerperDevTool .
:HealthcareMarketingAgent :agentToolUsage :WeaviateVectorSearchTool , :SerperDevTool .
:FinancialMarketingAgent :agentToolUsage :WeaviateVectorSearchTool , :SerperDevTool .

# Mark producedResource conceptually: tasks may produce analysis artifacts (modeled as beam:Instance resources)
:BiomedicalAnalysisReport rdf:type beam:Instance ;
    dct:title "Biomedical feature analysis report" ;
    dct:description "Output document expected from the biomedical agent task." .

:HealthcareAnalysisReport rdf:type beam:Instance ;
    dct:title "Healthcare feature analysis report" ;
    dct:description "Output document expected from the healthcare agent task." .

:FinancialAnalysisReport rdf:type beam:Instance ;
    dct:title "Financial feature analysis report" ;
    dct:description "Output document expected from the financial agent task." .

:Task_BiomedicalResearch :producedResource :BiomedicalAnalysisReport .
:Task_HealthcareResearch :producedResource :HealthcareAnalysisReport .
:Task_FinancialResearch :producedResource :FinancialAnalysisReport .

# All created Config individuals are referenced by the tool; ensure they are not orphaned (already linked via :hasToolConfig above).

# End of instance data.