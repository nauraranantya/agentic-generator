# Link the tool usage from each agent explicitly (agents.py: tools=ExaSearchTool.tools())
:Agent_ResearchSpecialist :agentToolUsage :Tool_ExaSearchTool .
:Agent_IndustryAnalyst :agentToolUsage :Tool_ExaSearchTool .
:Agent_MeetingStrategyAdvisor :agentToolUsage :Tool_ExaSearchTool .
:Agent_BriefingCoordinator :agentToolUsage :Tool_ExaSearchTool .

# Ensure Tool_ExaSearchTool config is connected (tools/ExaSearchTool._exa uses EXA_API_KEY env var)
:Tool_ExaSearchTool :hasToolConfig :Config_Exa_API .

# Ensure capabilities are connected to the tool
:Tool_ExaSearchTool :hasCapability :Capability_exa_search ,
                                 :Capability_exa_find_similar ,
                                 :Capability_exa_get_contents .

# Ensure each Prompt is referenced (already linked via :agentPrompt and :taskPrompt)
# Ensure Goals are linked to agents (hasAgentGoal above)
