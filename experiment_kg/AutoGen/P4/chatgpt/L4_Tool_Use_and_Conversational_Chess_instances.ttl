# Execution time: 60.00 seconds
# Model used: gpt-5-mini
# Prompt: P4

# VALIDATION
# Check 1 (Completeness): PASS
# Check 2 (Workflow Integrity): PASS
# Check 3 (Structural Consistency): PASS
# Check 4 (Schema Compliance): PASS
#
# Issues / Assumptions:
# - No issues detected. Assumptions: The notebook's final redefinitions of the agents (with taunting behavior) are used as the canonical agent prompts. The board proxy and the registered functions are modeled as Tool individuals and Tasks are linked to both agents (both agents register and may perform the tasks). The shared chess.Board state is modeled as a Memory instance.

@prefix : <http://www.w3id.org/agentic-ai/onto#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

#################################################################
#    Instances populated from L4_Tool_Use_and_Conversational_Chess.ipynb
#################################################################

:Team_Conversational_Chess rdf:type :Team ;
    rdfs:label "Conversational Chess Team" ;
    :hasAgentMember :Agent_White , :Agent_Black ;
    :hasWorkflowPattern :WorkflowPattern_ChessMatch .

### Agents
:Agent_White rdf:type :LLMAgent ;
    rdfs:label "执白棋者" ;
    :agentID "player_white" ;
    :agentRole "white" ;
    :agentPrompt :Prompt_Agent_White ;
    :hasAgentConfig :Config_Agent_White_Model ;
    :useLanguageModel :LM_gpt4 ;
    :agentToolUsage :Tool_getLegalMoves , :Tool_makeMove ;
    :hasKnowledge :Memory_ChessBoard .

:Agent_Black rdf:type :LLMAgent ;
    rdfs:label "执黑棋者" ;
    :agentID "player_black" ;
    :agentRole "black" ;
    :agentPrompt :Prompt_Agent_Black ;
    :hasAgentConfig :Config_Agent_Black_Model ;
    :useLanguageModel :LM_gpt4 ;
    :agentToolUsage :Tool_getLegalMoves , :Tool_makeMove ;
    :hasKnowledge :Memory_ChessBoard .

### Language Model
:LM_gpt4 rdf:type :LanguageModel ;
    rdfs:label "gpt-4-turbo" .

### Tools and Board Proxy
:Tool_BoardProxy rdf:type :Tool ;
    rdfs:label "棋盘裁判代理" ;
    :hasToolConfig :Config_BoardProxy_llmconfig , :Config_BoardProxy_default_auto_reply , :Config_BoardProxy_human_input_mode , :Config_BoardProxy_is_termination_msg .

:Tool_getLegalMoves rdf:type :Tool ;
    rdfs:label "get_legal_moves (tool)" .

:Tool_makeMove rdf:type :Tool ;
    rdfs:label "make_move (tool)" .

### Configurations (every :Config has :configKey and :configValue)
:Config_Agent_White_Model rdf:type :Config ;
    :configKey "model" ;
    :configValue "gpt-4-turbo" .

:Config_Agent_Black_Model rdf:type :Config ;
    :configKey "model" ;
    :configValue "gpt-4-turbo" .

:Config_BoardProxy_llmconfig rdf:type :Config ;
    :configKey "llm_config" ;
    :configValue "false" .

:Config_BoardProxy_default_auto_reply rdf:type :Config ;
    :configKey "default_auto_reply" ;
    :configValue "请走一步棋（move）:" .

:Config_BoardProxy_human_input_mode rdf:type :Config ;
    :configKey "human_input_mode" ;
    :configValue "NEVER" .

:Config_BoardProxy_is_termination_msg rdf:type :Config ;
    :configKey "is_termination_msg" ;
    :configValue "check_made_move" .

### Shared Knowledge / Memory (represents the chess.Board state)
:Memory_ChessBoard rdf:type :Memory ;
    rdfs:label "Shared chess.Board state" ;
    rdfs:comment "Represents the shared chess.Board state used by the board proxy and agents (initialised via chess.Board())." .

### Tasks (linked to agents via :performedByAgent and to executor via :performedBy)
:Task_GetLegalMoves rdf:type :Task ;
    rdfs:label "Get legal moves task" ;
    :taskPrompt :Prompt_GetLegalMoves ;
    :performedByAgent :Agent_White , :Agent_Black ;
    :performedBy :Tool_BoardProxy .

:Task_MakeMove rdf:type :Task ;
    rdfs:label "Make move task" ;
    :taskPrompt :Prompt_MakeMove ;
    :performedByAgent :Agent_White , :Agent_Black ;
    :performedBy :Tool_BoardProxy .

### Prompts (every :Prompt has :promptInstruction)
:Prompt_Agent_White rdf:type :Prompt ;
    rdfs:label "Prompt for Agent White" ;
    :promptInstruction """你是一个围棋高手，你执白棋。
                    1，首先调用 get_legal_moves() 获取一个合法棋步（moves）的列表；
                    2，在列表中选择一个合法棋布（move）后调用  make_move(move) 走一步棋;
                    3, 走完一步棋后，嘲讽对手增加游戏乐趣""" .

:Prompt_Agent_Black rdf:type :Prompt ;
    rdfs:label "Prompt for Agent Black" ;
    :promptInstruction """你是一个围棋高手，你执黑棋。
                    1，首先调用 get_legal_moves() 获取一个合法棋步（moves）的列表；
                    2，在列表中选择一个合法棋布（move）后调用  make_move(move) 走一步棋;
                    3, 走完一步棋后，嘲讽对手增加游戏乐趣""" .

:Prompt_GetLegalMoves rdf:type :Prompt ;
    rdfs:label "Prompt: get_legal_moves" ;
    :promptInstruction "获取合法棋步" ;
    :promptInputData "A list of legal moves in UCI format" .

:Prompt_MakeMove rdf:type :Prompt ;
    rdfs:label "Prompt: make_move" ;
    :promptInstruction "调用工具走一步棋" ;
    :promptInputData "move: A move in UCI format." ;
    :promptOutputIndicator "Result of the move." .

### Workflow Pattern and Steps (steps have :stepOrder, are chained with :nextStep, and each links to at least one task)
:WorkflowPattern_ChessMatch rdf:type :WorkflowPattern ;
    rdfs:label "Conversational Chess Match Pattern" ;
    :hasWorkflowStep :Step_1 , :Step_2 , :Step_3 .

:Step_1 rdf:type :StartStep ;
    rdfs:label "Start: Request legal moves" ;
    :stepOrder 1 ;
    :hasAssociatedTask :Task_GetLegalMoves ;
    :nextStep :Step_2 .

:Step_2 rdf:type :WorkflowStep ;
    rdfs:label "Make move" ;
    :stepOrder 2 ;
    :hasAssociatedTask :Task_MakeMove ;
    :nextStep :Step_3 .

:Step_3 rdf:type :EndStep ;
    rdfs:label "End: Update board and refresh legal moves" ;
    :stepOrder 3 ;
    :hasAssociatedTask :Task_GetLegalMoves .

#################################################################
#    Links / Notes
#################################################################

# - Both agents register the same tools (get_legal_moves, make_move) and thus both are linked to those Tool individuals via :agentToolUsage.
# - The board proxy acts as the executor tool (Tool_BoardProxy) and is the :performedBy value for the tasks.
# - The workflow pattern models a simple request-move-update chain: StartStep -> MakeMove -> EndStep (which refreshes legal moves).
# - All individuals are connected; all Config and Prompt constraints specified in validation are satisfied.